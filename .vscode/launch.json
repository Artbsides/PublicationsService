{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Api: launch",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app", "--reload", "--loop", "uvloop", "--http", "httptools"
            ],
            "jinja": true,
            "justMyCode": true
        },
        {
            "name": "Api: Attach",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "0.0.0.0",
                "port": 5678
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}",
                    "remoteRoot": "."
                }
            ],
            "justMyCode": true
        },
        {
            "name": "Worker: launch",
            "type": "debugpy",
            "request": "launch",
            "module": "celery",
            "args": [
                "-A", "workers.process_uploaded_file.app", "worker", "--loglevel=info", "--concurrency=2", "-E",
            ],
            "jinja": true,
            "justMyCode": true
        },
        {
            "name": "File: Launch",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "jinja": true,
            "justMyCode": false
        },
        {
            "name": "Integration Tests: launch",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/integration",
                "-vv"
            ],
            "jinja": true,
            "justMyCode": true
        },
        {
            "name": "Unit Tests: launch",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/unit",
                "-vv"
            ],
            "jinja": true,
            "justMyCode": true
        }
    ]
}
